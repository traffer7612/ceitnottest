PORT=3002
# Engine proxy — stats + /api/config/contracts
CEITNOT_ENGINE_ADDRESS=0x0000000000000000000000000000000000000000
# Block where the engine proxy was deployed (required on mainnet/testnet for “unique wallets” on landing).
# Local Anvil (31337): omit or use 0
# CEITNOT_ENGINE_DEPLOY_BLOCK=12345678
# CEITNOT_REGISTRY_ADDRESS=0x...
# CEITNOT_VAULT_4626_ADDRESS=0x...
# RPC for viem (stats + reads). Also accepts chain-specific aliases used on Railway:
# RPC_URL=https://…
# ARBITRUM_RPC_URL=https://arbitrum-mainnet.infura.io/v3/…   # used when CEITNOT stats chainId is 42161
# ARBITRUM_SEPOLIA_RPC_URL=https://…                         # chainId 421614

# Faucet (local Anvil): POST /api/faucet/ — sends 0.5 ETH to requested address
# FAUCET_PRIVATE_KEY=0xac0974bec39a17e36ba4a6b4d238ff944bacb478cbed5efcae784d7bf4f2ff80
# FAUCET_RPC_URL=http://127.0.0.1:8545

# Governance token mint (testnet): POST /api/faucet/mint-governance — mints 1000 CEITNOT (18 decimals) to the requested address.
# FAUCET_PRIVATE_KEY must be the token minter. Set GOVERNANCE_TOKEN_ADDRESS to CeitnotToken.
#
# Deploy log line: CEITNOT_TOKEN: 0x...
#
# FAUCET_PRIVATE_KEY=0x...
# GOVERNANCE_TOKEN_ADDRESS=0x...
